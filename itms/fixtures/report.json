  "module": "ITMS",
  "name": "Intern Performance Summary",
  "prepared_report": 0,
  "query": null,
  "ref_doctype": "Intern",
  "reference_report": null,
  "report_name": "Intern Performance Summary",
  "report_script": "def execute(filters=None):\r\n    if not filters:\r\n        filters = {}\r\n\r\n    columns = [\r\n        {\"label\": \"Intern\", \"fieldname\": \"intern\", \"fieldtype\": \"Data\", \"width\": 150},\r\n        {\"label\": \"Total Logs\", \"fieldname\": \"total_logs\", \"fieldtype\": \"Int\", \"width\": 100},\r\n        {\"label\": \"Total Hours\", \"fieldname\": \"total_hours\", \"fieldtype\": \"Float\", \"width\": 100},\r\n        {\"label\": \"Approved\", \"fieldname\": \"approved\", \"fieldtype\": \"Int\", \"width\": 100},\r\n        {\"label\": \"Rejected\", \"fieldname\": \"rejected\", \"fieldtype\": \"Int\", \"width\": 100},\r\n        {\"label\": \"Late Submissions\", \"fieldname\": \"late\", \"fieldtype\": \"Int\", \"width\": 130},\r\n        {\"label\": \"Attendance %\", \"fieldname\": \"attendance_percentage\", \"fieldtype\": \"Percent\", \"width\": 120},\r\n        {\"label\": \"Present Days\", \"fieldname\": \"present_days\", \"fieldtype\": \"Int\", \"width\": 110},\r\n        {\"label\": \"Status\", \"fieldname\": \"status\", \"fieldtype\": \"Data\", \"width\": 100},\r\n    ]\r\n\r\n    intern_filter = {}\r\n    if filters.get(\"intern\"):\r\n        intern_filter[\"name\"] = filters[\"intern\"]\r\n\r\n    interns = frappe.db.get_all(\r\n        \"Intern\",\r\n        filters=intern_filter,\r\n        fields=[\"name\", \"attendance_percentage\", \"present_days\", \"total_working_days\"]\r\n    )\r\n\r\n    data = []\r\n    for intern in interns:\r\n        lf = {\"intern\": intern.name}\r\n\r\n        total_logs = frappe.db.count(\"Daily Work Logs\", lf)\r\n        total_hours = frappe.db.get_value(\r\n            \"Daily Work Logs\", lf, \"sum(hours_worked)\"\r\n        ) or 0\r\n        approved = frappe.db.count(\"Daily Work Logs\", {**lf, \"status\": \"Approved\"})\r\n        rejected = frappe.db.count(\"Daily Work Logs\", {**lf, \"status\": \"Rejected\"})\r\n        late = frappe.db.count(\"Daily Work Logs\", {**lf, \"is_late\": 1})\r\n\r\n        att = intern.attendance_percentage or 0\r\n        status = \"Good\" if att >= 75 else \"At Risk\"\r\n\r\n        data.append({\r\n            \"intern\": intern.name,\r\n            \"total_logs\": total_logs,\r\n            \"total_hours\": round(total_hours, 2),\r\n            \"approved\": approved,\r\n            \"rejected\": rejected,\r\n            \"late\": late,\r\n            \"attendance_percentage\": att,\r\n            \"present_days\": intern.present_days or 0,\r\n            \"status\": status,\r\n        })\r\n\r\n    return columns, data",
  "report_type": "Script Report",
