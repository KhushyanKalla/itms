  "html": "<style>\r\n    /* Reset Frappe's default print padding */\r\n    .print-format {\r\n        padding: 0px !important; \r\n        background-color: white;\r\n    }\r\n    \r\n    .cert-container {\r\n        font-family: \"Georgia\", serif;\r\n        text-align: center;\r\n        color: #1a2a3a;\r\n        padding: 30px;\r\n        background: #fff;\r\n    }\r\n\r\n    .cert-outer-border {\r\n        border: 12px solid #1a2a3a; /* Deep Navy */\r\n        padding: 12px;\r\n        background-color: #fcfcf9; /* Subtle Parchment Tint */\r\n    }\r\n\r\n    .cert-inner-border {\r\n        border: 3px solid #d4af37; /* Rich Gold */\r\n        padding: 50px 40px;\r\n        position: relative;\r\n        min-height: 600px;\r\n    }\r\n\r\n    .watermark-bg {\r\n        position: absolute;\r\n        top: 50%;\r\n        left: 50%;\r\n        transform: translate(-50%, -50%);\r\n        font-size: 160px;\r\n        color: rgba(212, 175, 55, 0.04); /* Very faint gold */\r\n        font-weight: bold;\r\n        z-index: 0;\r\n        pointer-events: none;\r\n        letter-spacing: 25px;\r\n    }\r\n\r\n    .cert-content {\r\n        position: relative;\r\n        z-index: 1;\r\n    }\r\n\r\n    .header-logo {\r\n        font-size: 36px;\r\n        font-weight: 900;\r\n        letter-spacing: 10px;\r\n        color: #1a2a3a;\r\n        margin-bottom: 5px;\r\n    }\r\n\r\n    .header-sub {\r\n        font-size: 11px;\r\n        font-family: \"Helvetica\", \"Arial\", sans-serif;\r\n        color: #718096;\r\n        letter-spacing: 3px;\r\n        text-transform: uppercase;\r\n        margin-bottom: 50px;\r\n    }\r\n\r\n    .cert-title {\r\n        font-size: 54px;\r\n        font-weight: normal;\r\n        color: #1a2a3a;\r\n        letter-spacing: 6px;\r\n        text-transform: uppercase;\r\n        margin-bottom: 5px;\r\n    }\r\n\r\n    .cert-subtitle {\r\n        font-size: 16px;\r\n        font-family: \"Helvetica\", \"Arial\", sans-serif;\r\n        color: #d4af37;\r\n        letter-spacing: 5px;\r\n        text-transform: uppercase;\r\n        margin-bottom: 40px;\r\n    }\r\n\r\n    .presented-text {\r\n        font-size: 18px;\r\n        font-style: italic;\r\n        color: #4a5568;\r\n        margin-bottom: 20px;\r\n    }\r\n\r\n    .intern-name {\r\n        font-size: 48px;\r\n        font-weight: bold;\r\n        color: #1a2a3a;\r\n        border-bottom: 2px solid #d4af37;\r\n        display: inline-block;\r\n        padding: 0 50px 10px 50px;\r\n        margin-bottom: 30px;\r\n        font-style: italic;\r\n    }\r\n\r\n    .cert-body {\r\n        font-size: 16px;\r\n        color: #4a5568;\r\n        line-height: 1.8;\r\n        max-width: 750px;\r\n        margin: 0 auto 40px auto;\r\n    }\r\n\r\n    /* PDF-Safe Table for Stats */\r\n    .stats-table {\r\n        width: 85%;\r\n        margin: 0 auto 50px auto;\r\n        border-collapse: collapse;\r\n    }\r\n\r\n    .stats-table th {\r\n        font-family: \"Helvetica\", \"Arial\", sans-serif;\r\n        font-size: 10px;\r\n        color: #718096;\r\n        text-transform: uppercase;\r\n        letter-spacing: 2px;\r\n        padding: 10px;\r\n        border-top: 1px solid rgba(212, 175, 55, 0.4);\r\n        border-bottom: 1px solid rgba(212, 175, 55, 0.4);\r\n    }\r\n\r\n    .stats-table td {\r\n        font-size: 18px;\r\n        font-weight: bold;\r\n        color: #1a2a3a;\r\n        padding: 15px 10px;\r\n        border-bottom: 1px solid rgba(212, 175, 55, 0.4);\r\n    }\r\n\r\n    /* PDF-Safe Alignment for Signatures */\r\n    .signature-section {\r\n        display: table;\r\n        width: 100%;\r\n        margin-top: 30px;\r\n    }\r\n\r\n    .signature-block {\r\n        display: table-cell;\r\n        width: 50%;\r\n        text-align: center;\r\n        vertical-align: bottom;\r\n    }\r\n\r\n    .signature-line {\r\n        border-top: 1px solid #1a2a3a;\r\n        width: 220px;\r\n        margin: 0 auto 10px auto;\r\n    }\r\n\r\n    .signature-name {\r\n        font-family: \"Helvetica\", \"Arial\", sans-serif;\r\n        font-size: 14px;\r\n        font-weight: bold;\r\n        color: #1a2a3a;\r\n        margin-bottom: 4px;\r\n        text-transform: uppercase;\r\n        letter-spacing: 1px;\r\n    }\r\n\r\n    .signature-role {\r\n        font-family: \"Helvetica\", \"Arial\", sans-serif;\r\n        font-size: 11px;\r\n        color: #718096;\r\n        text-transform: uppercase;\r\n        letter-spacing: 1px;\r\n    }\r\n\r\n    .footer-id {\r\n        margin-top: 50px;\r\n        font-family: \"Helvetica\", \"Arial\", sans-serif;\r\n        font-size: 10px;\r\n        color: #a0aec0;\r\n        letter-spacing: 1px;\r\n    }\r\n</style>\r\n\r\n<div class=\"cert-container\">\r\n    <div class=\"cert-outer-border\">\r\n        <div class=\"cert-inner-border\">\r\n            \r\n            <div class=\"watermark-bg\">ITMS</div>\r\n            \r\n            <div class=\"cert-content\">\r\n\r\n                <div class=\"header-logo\">ITMS</div>\r\n                <div class=\"header-sub\">Internship & Training Management System</div>\r\n\r\n                <div class=\"cert-title\">Certificate</div>\r\n                <div class=\"cert-subtitle\">Of Internship Completion</div>\r\n\r\n                <div class=\"presented-text\">This is proudly presented to</div>\r\n\r\n                <div class=\"intern-name\">{{ doc.intern_name or doc.name }}</div>\r\n\r\n                <div class=\"cert-body\">\r\n                    has successfully completed the internship program under the expert mentorship of \r\n                    <strong>{{ doc.mentor }}</strong>. During this tenure, the intern demonstrated outstanding dedication, technical proficiency, and a commitment to continuous professional growth.\r\n                </div>\r\n\r\n                <table class=\"stats-table\">\r\n                    <thead>\r\n                        <tr>\r\n                            <th>Joining Date</th>\r\n                            <th>Completion Date</th>\r\n                            <th>Attendance</th>\r\n                            <th>Total Logs</th>\r\n                        </tr>\r\n                    </thead>\r\n                    <tbody>\r\n                        <tr>\r\n                            <td>{{ frappe.utils.formatdate(doc.joining_date) if doc.joining_date else \"N/A\" }}</td>\r\n                            <td>{{ frappe.utils.formatdate(doc.completion_date) if doc.completion_date else \"N/A\" }}</td>\r\n                            <td>{{ doc.attendance_percentage }}%</td>\r\n                            <td>{{ frappe.db.count(\"Daily Work Logs\", {\"intern\": doc.name}) }}</td>\r\n                        </tr>\r\n                    </tbody>\r\n                </table>\r\n\r\n                <div class=\"signature-section\">\r\n                    <div class=\"signature-block\">\r\n                        <div class=\"signature-line\"></div>\r\n                        <div class=\"signature-name\">{{ doc.mentor }}</div>\r\n                        <div class=\"signature-role\">Assigned Mentor</div>\r\n                    </div>\r\n                    <div class=\"signature-block\">\r\n                        <div class=\"signature-line\"></div>\r\n                        <div class=\"signature-name\">Program Director</div>\r\n                        <div class=\"signature-role\">ITMS Administration</div>\r\n                    </div>\r\n                </div>\r\n\r\n                <div class=\"footer-id\">\r\n                    ISSUED ON {{ frappe.utils.formatdate(frappe.utils.today()) | upper }} &nbsp;|&nbsp; CERTIFICATE ID: {{ doc.name }}-CERT\r\n                </div>\r\n\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>",
